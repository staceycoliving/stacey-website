generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── LOCATIONS ───────────────────────────────────────────

model Location {
  id        String   @id @default(cuid())
  slug      String   @unique // z.B. "muehlenkamp", "alster"
  name      String   // z.B. "Mühlenkamp", "Alster"
  city      String   // z.B. "Hamburg", "Berlin"
  address   String
  stayType  StayType // SHORT oder LONG

  apartments Apartment[] // nur LONG Stay
  bookings   Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StayType {
  SHORT
  LONG
}

// ─── LONG STAY: Apartments & Zimmer ─────────────────────

model Apartment {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])

  houseNumber String   // Hausnummer
  floor       String   // Stockwerk (z.B. "EG", "1.OG", "2.OG")
  label       String?  // Optionaler Name (z.B. "Vorderhaus")

  rooms Room[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

model Room {
  id          String       @id @default(cuid())
  apartmentId String
  apartment   Apartment    @relation(fields: [apartmentId], references: [id])

  roomNumber       String       // Zimmernummer (z.B. "201")
  category         RoomCategory // Cozy, Comfy, Jumbo, etc.
  monthlyRent      Int          @default(0) // Monatliche Miete in Cent
  buildingAddress  String?      // Hausnummer wenn abweichend (z.B. "Dorotheenstraße 3")
  floorDescription String?      // Stockwerk + Lage (z.B. "3. OG rechts")
  status           RoomStatus   @default(ACTIVE)

  tenant   Tenant? // Aktueller Mieter (oder null = frei)
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apartmentId])
}

enum RoomStatus {
  ACTIVE       // Buchbar
  BLOCKED      // Temporär gesperrt (Renovation, etc.)
  DEACTIVATED  // Nicht mehr im Inventar
}

enum RoomCategory {
  BASIC_PLUS        // Basic+
  MIGHTY            // Mighty
  PREMIUM           // Premium
  PREMIUM_PLUS      // Premium+
  PREMIUM_BALCONY   // Premium Balcony
  PREMIUM_PLUS_BALCONY // Premium+ Balcony
  JUMBO             // Jumbo
  JUMBO_BALCONY     // Jumbo Balcony
  STUDIO            // Studio
  DUPLEX            // Duplex
}

// ─── LONG STAY: Aktuelle Mieter ─────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  roomId    String   @unique
  room      Room     @relation(fields: [roomId], references: [id])
  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id])

  firstName String
  lastName  String
  email     String
  phone     String?
  dateOfBirth DateTime?
  street      String?
  zipCode     String?
  addressCity String?
  country     String?

  monthlyRent Int @default(0) // Miete in Cent (Snapshot bei Einzug)

  moveIn    DateTime // Einzugsdatum
  moveOut   DateTime? // Geplantes Auszugsdatum (null = keine Kündigung)
  notice    DateTime? // Kündigungsdatum (wann wurde gekündigt)

  // Stripe / SEPA
  stripeCustomerId String?
  sepaMandateId    String?

  // Kaution
  depositAmount       Int?
  depositStatus       DepositStatus @default(PENDING)
  damagesAmount       Int           @default(0) // Mängel in Cent
  arrearsAmount       Int           @default(0) // Mietrückstände in Cent
  rentOverpaymentAmount Int         @default(0) // Mietüberzahlung in Cent (z.B. nach moveOut-Verkürzung)
  depositRefundAmount Int?          // Kaution + Überzahlung - Mängel - Rückstände
  depositRefundIban   String?
  depositReturnedAt   DateTime?

  // Emails
  welcomeEmailSentAt           DateTime?
  paymentSetupRemindersSent    Int       @default(0) // Counter: 0..3
  paymentFinalWarningSentAt    DateTime?
  postStayFeedbackSentAt       DateTime?

  rentPayments    RentPayment[]
  extraCharges    ExtraCharge[]
  rentAdjustments RentAdjustment[]
  defects         Defect[]
  notes           Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── FOLIO: Zusatzkosten, Mietanpassungen, Mängel, Notizen ──

model ExtraCharge {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  description String   // z.B. "Schlüsselersatz", "Heizungsausfall"
  amount      Int      // Cent (immer positiv — Vorzeichen ergibt sich aus type)
  month       DateTime? // Optional: welchem Monat zuordnen (null = einmalig)
  paidAt      DateTime? // Null = offen

  type        ExtraChargeType   @default(CHARGE)   // CHARGE = Mieter schuldet uns, DISCOUNT = Nachlass
  chargeOn    ExtraChargeTiming @default(NEXT_RENT) // NEXT_RENT = mit nächster Miete, DEPOSIT_SETTLEMENT = am Ende

  stripePaymentIntentId String? // Gesetzt wenn via Monats-SEPA mit eingezogen wurde

  createdBy   String?  // Admin-User (erstmal optional)
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

enum ExtraChargeType {
  CHARGE
  DISCOUNT
}

enum ExtraChargeTiming {
  NEXT_RENT
  DEPOSIT_SETTLEMENT
}

model RentAdjustment {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  month           DateTime? // Null = permanent
  originalAmount  Int       // Cent (Snapshot vor Anpassung)
  adjustedAmount  Int       // Cent (neuer Betrag)
  reason          String
  isPermanent     Boolean   @default(false)
  validFrom       DateTime? // Nur bei isPermanent = true

  createdBy       String?
  createdAt       DateTime  @default(now())

  @@index([tenantId])
}

model Defect {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  description     String
  deductionAmount Int      // Cent
  photos          String[] // Google Drive Links

  createdBy       String?
  createdAt       DateTime @default(now())

  @@index([tenantId])
}

model Note {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  content   String
  createdBy String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ─── BUCHUNGEN (SHORT + LONG) ───────────────────────────

model Booking {
  id         String        @id @default(cuid())
  locationId String
  location   Location      @relation(fields: [locationId], references: [id])

  stayType   StayType
  category   RoomCategory
  persons    Int           @default(1)

  // SHORT Stay: Check-in/Check-out Zeitraum
  checkIn    DateTime?
  checkOut   DateTime?

  // LONG Stay: Move-in Datum + zugewiesenes Zimmer (optional, wird intern zugewiesen)
  moveInDate DateTime?
  roomId     String?
  room       Room?         @relation(fields: [roomId], references: [id])

  // Persönliche Daten
  firstName  String
  lastName   String
  email      String
  phone      String
  dateOfBirth DateTime?    // nur LONG
  street      String?      // nur LONG
  zipCode     String?      // nur LONG
  addressCity String?      // nur LONG
  country     String?      // nur LONG

  // Buchungsdetails
  monthlyRent    Int?      // Monatliche Miete in Cent
  moveInReason   String?
  message        String?

  // Vertrag (Yousign)
  signatureRequestId   String?   @unique
  signatureDocumentId  String?   // Yousign Document ID für Download

  // Booking Fee (EUR 195)
  bookingFeeSessionId  String?   @unique  // Stripe Checkout Session ID
  bookingFeePaidAt     DateTime?

  // Kaution
  depositAmount         Int?      // Kaution in Cent (2× Monatsmiete)
  depositStatus         DepositStatus @default(PENDING)
  depositPaymentLinkId  String?   // Stripe Payment Link ID
  depositPaymentLinkUrl String?   // URL für Gast
  depositDeadline       DateTime? // 48h nach Booking Fee
  depositPaidAt         DateTime?
  depositReminderSentAt DateTime? // 24h Reminder vor Deadline

  // Tenant (Rück-Referenz)
  tenant     Tenant?

  // Status
  status             BookingStatus @default(PENDING)
  cancellationReason String?       // z.B. "Widerruf", "Deposit timeout", "Kundenwunsch"

  // Widerruf-spezifisch (gesetzt vom withdraw route)
  cancellationDate       DateTime?  // Wann der Widerruf bei uns einging
  proRataRentRetained    Int?       // anteilige Miete einbehalten in Cent (wenn schon eingezogen)
  depositRefundedAmount  Int?       // tatsächlich an Kunde refundeter Betrag in Cent

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([locationId])
  @@index([status])
  @@index([checkIn, checkOut])
  @@index([depositDeadline])
}

enum BookingStatus {
  PENDING          // Buchung angelegt, Vertrag noch nicht unterschrieben
  SIGNED           // Vertrag unterschrieben, Booking Fee ausstehend
  PAID             // Booking Fee bezahlt, Deposit-Link verschickt
  DEPOSIT_PENDING  // Warten auf Kaution (48h Frist)
  CONFIRMED        // Kaution bezahlt, Tenant angelegt
  CANCELLED        // Storniert
}

enum DepositStatus {
  PENDING      // Noch nicht bezahlt
  RECEIVED     // Eingegangen
  RETURNED     // Zurückgezahlt
  RETAINED     // Einbehalten
}

// ─── MIET-TRACKING ──────────────────────────────────────

model RentPayment {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  month     DateTime // 1. des Monats (z.B. 2026-05-01)
  amount    Int      // Erwarteter Betrag in Cent
  paidAmount Int     @default(0) // Tatsächlich gezahlt in Cent
  status    RentPaymentStatus @default(PENDING)

  stripePaymentIntentId String?
  paidAt    DateTime?
  failedAt  DateTime?
  failureReason String?

  // Retry-Tracking
  lastRetryAt DateTime? // Last SEPA retry attempt (at most once/day)

  // Mahnung-Tracking
  reminder1SentAt DateTime? // Tag 3: freundliche Erinnerung
  mahnung1SentAt  DateTime? // Tag 14: 1. Mahnung
  mahnung2SentAt  DateTime? // Tag 30: 2. Mahnung + Kündigungsandrohung

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, month])
  @@index([tenantId])
  @@index([status])
  @@index([month])
}

enum RentPaymentStatus {
  PENDING     // Noch nicht versucht
  PROCESSING  // SEPA Lastschrift initiiert
  PAID        // Bestätigt
  FAILED      // Fehlgeschlagen
  PARTIAL     // Teilweise bezahlt (manuelle Anpassung)
}

// Idempotency log for incoming webhooks (Stripe + Yousign + …).
// On every webhook, we try to insert the provider-supplied event ID. The
// `@unique` constraint guarantees a duplicate insert fails fast, so the
// handler can short-circuit before doing anything observable (creating
// tenants, sending emails, hitting Stripe again).
model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String   // "stripe" | "yousign" | …
  eventId     String   // The provider's event ID, e.g. evt_1AbCdEf…
  eventType   String?  // Cosmetic, useful for inspection
  receivedAt  DateTime @default(now())

  @@unique([provider, eventId])
  @@index([receivedAt])
}

// ─── AUDIT LOG ─────────────────────────────────────────────

// Team pinboard — shared notes the admin team leaves for each other.
// Not scoped to a specific tenant by default; optional tenantId link
// lets admins attach a note to a tenant from their folio.
model TeamNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  content   String
  author    String?  // display name — free text for now, no user auth yet
  sticky    Boolean  @default(false)
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([sticky])
}

// Log of every email sent (auto or manual). Feeds the dashboard widget
// and the /admin/emails page.
model SentEmail {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text"))
  templateKey String
  recipient   String
  subject     String?
  entityType  String?
  entityId    String?
  resendId    String?
  status      String   @default("sent") // "sent" | "failed"
  error       String?
  triggeredBy String   @default("auto") // "auto" | "manual_resend" | "cron"
  sentAt      DateTime @default(now())

  @@index([sentAt])
  @@index([recipient])
  @@index([templateKey])
  @@index([entityType, entityId])
}

model AuditLog {
  id         String   @id @default(cuid())
  at         DateTime @default(now())

  // Module groups related routes — e.g. "tenant", "booking", "deposit",
  // "rooms", "housekeeping", "finance", "rent", "auth".
  module     String

  // HTTP-style action: "PATCH", "POST", "DELETE", "GET" (rare),
  // or a domain-specific verb like "withdraw", "send_settlement".
  action     String

  // What was acted on: tenantId, bookingId, etc. — free-form.
  entityType String?
  entityId   String?

  // Human-readable summary line.
  summary    String?

  // Free-form JSON for diff or context — kept small.
  metadata   Json?

  // Path + IP for audit trail.
  path       String?
  ip         String?

  @@index([at])
  @@index([module])
  @@index([entityType, entityId])
}

// ─── HOUSEKEEPING ──────────────────────────────────────────

model CleaningTask {
  id           String   @id @default(cuid())

  // External reference key — composed from source + tenant/reservation + type:
  //   "tenant-<id>-in", "tenant-<id>-out"
  //   "apaleo-<resId>-in", "apaleo-<resId>-out"
  // Used to upsert when the underlying source data changes.
  taskKey      String   @unique

  taskType     CleaningTaskType
  date         DateTime         // Day the work is scheduled for
  locationSlug String?
  roomLabel    String?          // human-readable room reference
  guestName    String?

  status       CleaningTaskStatus @default(OPEN)
  assignedTo   String?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([locationSlug])
  @@index([status])
}

enum CleaningTaskType {
  MOVE_IN
  MOVE_OUT
}

enum CleaningTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

// ─── SHORT STAY: Email-Tracking per apaleo Reservation ──

model ShortStayEmailLog {
  id                       String    @id @default(cuid())
  apaleoReservationId      String    @unique // apaleo reservation ID
  guestEmail               String
  locationSlug             String

  preArrivalSentAt         DateTime?
  checkoutReminderSentAt   DateTime?
  postStayFeedbackSentAt   DateTime?
  invoiceSentAt            DateTime?

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([apaleoReservationId])
}

// ─── SHORT STAY: Meldeschein (Guest Registration) ───────

model Meldeschein {
  id                    String   @id @default(cuid())
  apaleoReservationId   String   @unique

  // Gast-Daten
  firstName             String
  lastName              String
  dateOfBirth           DateTime
  nationality           String
  idDocumentType        String   // "passport" | "id_card"
  idDocumentNumber      String

  // Anschrift (Heimatadresse)
  street                String
  zipCode               String
  city                  String
  country               String

  // Aufenthalt
  arrivalDate           DateTime
  departureDate         DateTime
  locationSlug          String

  // Begleitperson (optional)
  companionFirstName    String?
  companionLastName     String?

  // PDF
  pdfData               Bytes?    // Generated Meldeschein PDF

  // Status
  completedAt           DateTime  @default(now())

  createdAt             DateTime  @default(now())

  @@index([apaleoReservationId])
  @@index([locationSlug])
}
