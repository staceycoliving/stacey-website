generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── LOCATIONS ───────────────────────────────────────────

model Location {
  id        String   @id @default(cuid())
  slug      String   @unique // z.B. "muehlenkamp", "alster"
  name      String   // z.B. "Mühlenkamp", "Alster"
  city      String   // z.B. "Hamburg", "Berlin"
  address   String
  stayType  StayType // SHORT oder LONG

  apartments Apartment[] // nur LONG Stay
  bookings   Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StayType {
  SHORT
  LONG
}

// ─── LONG STAY: Apartments & Zimmer ─────────────────────

model Apartment {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])

  houseNumber String   // Hausnummer
  floor       String   // Stockwerk (z.B. "EG", "1.OG", "2.OG")
  label       String?  // Optionaler Name (z.B. "Vorderhaus")

  rooms Room[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

model Room {
  id          String       @id @default(cuid())
  apartmentId String
  apartment   Apartment    @relation(fields: [apartmentId], references: [id])

  roomNumber  String       // Zimmernummer (z.B. "201")
  category    RoomCategory // Cozy, Comfy, Jumbo, etc.
  monthlyRent Int          @default(0) // Monatliche Miete in Cent

  tenant   Tenant? // Aktueller Mieter (oder null = frei)
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apartmentId])
}

enum RoomCategory {
  BASIC_PLUS        // Basic+
  MIGHTY            // Mighty
  PREMIUM           // Premium
  PREMIUM_PLUS      // Premium+
  PREMIUM_BALCONY   // Premium Balcony
  PREMIUM_PLUS_BALCONY // Premium+ Balcony
  JUMBO             // Jumbo
  JUMBO_BALCONY     // Jumbo Balcony
  STUDIO            // Studio
  DUPLEX            // Duplex
}

// ─── LONG STAY: Aktuelle Mieter ─────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  roomId    String   @unique
  room      Room     @relation(fields: [roomId], references: [id])
  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id])

  firstName String
  lastName  String
  email     String
  phone     String?
  dateOfBirth DateTime?
  street      String?
  zipCode     String?
  addressCity String?
  country     String?

  monthlyRent Int @default(0) // Miete in Cent (Snapshot bei Einzug)

  moveIn    DateTime // Einzugsdatum
  moveOut   DateTime? // Geplantes Auszugsdatum (null = keine Kündigung)
  notice    DateTime? // Kündigungsdatum (wann wurde gekündigt)

  // Stripe / SEPA
  stripeCustomerId String?
  sepaMandateId    String?

  // Kaution
  depositAmount       Int?
  depositStatus       DepositStatus @default(PENDING)
  damagesAmount       Int           @default(0) // Mängel in Cent
  arrearsAmount       Int           @default(0) // Mietrückstände in Cent
  depositRefundAmount Int?          // Kaution - Mängel - Rückstände
  depositRefundIban   String?
  depositReturnedAt   DateTime?

  // Emails
  welcomeEmailSentAt DateTime?

  rentPayments RentPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── BUCHUNGEN (SHORT + LONG) ───────────────────────────

model Booking {
  id         String        @id @default(cuid())
  locationId String
  location   Location      @relation(fields: [locationId], references: [id])

  stayType   StayType
  category   RoomCategory
  persons    Int           @default(1)

  // SHORT Stay: Check-in/Check-out Zeitraum
  checkIn    DateTime?
  checkOut   DateTime?

  // LONG Stay: Move-in Datum + zugewiesenes Zimmer (optional, wird intern zugewiesen)
  moveInDate DateTime?
  roomId     String?
  room       Room?         @relation(fields: [roomId], references: [id])

  // Persönliche Daten
  firstName  String
  lastName   String
  email      String
  phone      String
  dateOfBirth DateTime?    // nur LONG
  street      String?      // nur LONG
  zipCode     String?      // nur LONG
  addressCity String?      // nur LONG
  country     String?      // nur LONG

  // Buchungsdetails
  monthlyRent    Int?      // Monatliche Miete in Cent
  moveInReason   String?
  message        String?

  // Vertrag (Yousign)
  signatureRequestId   String?   @unique
  signatureDocumentId  String?   // Yousign Document ID für Download

  // Booking Fee (EUR 195)
  bookingFeeSessionId  String?   @unique  // Stripe Checkout Session ID
  bookingFeePaidAt     DateTime?

  // Kaution
  depositAmount         Int?      // Kaution in Cent (2× Monatsmiete)
  depositStatus         DepositStatus @default(PENDING)
  depositPaymentLinkId  String?   // Stripe Payment Link ID
  depositPaymentLinkUrl String?   // URL für Gast
  depositDeadline       DateTime? // 48h nach Booking Fee
  depositPaidAt         DateTime?

  // Tenant (Rück-Referenz)
  tenant     Tenant?

  // Status
  status     BookingStatus @default(PENDING)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([locationId])
  @@index([status])
  @@index([checkIn, checkOut])
  @@index([depositDeadline])
}

enum BookingStatus {
  PENDING          // Buchung angelegt, Vertrag noch nicht unterschrieben
  SIGNED           // Vertrag unterschrieben, Booking Fee ausstehend
  PAID             // Booking Fee bezahlt, Deposit-Link verschickt
  DEPOSIT_PENDING  // Warten auf Kaution (48h Frist)
  CONFIRMED        // Kaution bezahlt, Tenant angelegt
  CANCELLED        // Storniert
}

enum DepositStatus {
  PENDING      // Noch nicht bezahlt
  RECEIVED     // Eingegangen
  RETURNED     // Zurückgezahlt
  RETAINED     // Einbehalten
}

// ─── MIET-TRACKING ──────────────────────────────────────

model RentPayment {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  month     DateTime // 1. des Monats (z.B. 2026-05-01)
  amount    Int      // Erwarteter Betrag in Cent
  paidAmount Int     @default(0) // Tatsächlich gezahlt in Cent
  status    RentPaymentStatus @default(PENDING)

  stripePaymentIntentId String?
  paidAt    DateTime?
  failedAt  DateTime?
  failureReason String?

  // Mahnung-Tracking
  reminder1SentAt DateTime? // Tag 3: freundliche Erinnerung
  mahnung1SentAt  DateTime? // Tag 14: 1. Mahnung
  mahnung2SentAt  DateTime? // Tag 30: 2. Mahnung + Kündigungsandrohung

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, month])
  @@index([tenantId])
  @@index([status])
  @@index([month])
}

enum RentPaymentStatus {
  PENDING     // Noch nicht versucht
  PROCESSING  // SEPA Lastschrift initiiert
  PAID        // Bestätigt
  FAILED      // Fehlgeschlagen
  PARTIAL     // Teilweise bezahlt (manuelle Anpassung)
}
