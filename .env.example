# All env vars are validated by lib/env.ts at startup. Missing/invalid → build fails.
# Copy this file to .env.local for development. Keep .env.local out of git.

# ─── Database (Supabase) ─────────────────────────────────────
# Pooled connection (used by app — but db.ts uses DIRECT_URL anyway)
DATABASE_URL="postgres://USER:PASS@HOST:6543/postgres?pgbouncer=true"
# Direct connection (no pgbouncer) — required for interactive transactions
DIRECT_URL="postgres://USER:PASS@HOST:5432/postgres"

# ─── apaleo PMS (SHORT stay: Alster + Downtown) ──────────────
APALEO_CLIENT_ID=""
APALEO_CLIENT_SECRET=""

# ─── Stripe ──────────────────────────────────────────────────
# sk_test_... in dev, sk_live_... in production
STRIPE_SECRET_KEY="sk_test_..."
# whsec_... — get from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Resend (transactional email) ────────────────────────────
RESEND_API_KEY="re_..."

# ─── Yousign (lease signing) ─────────────────────────────────
YOUSIGN_API_KEY=""
# Sandbox by default. Override to https://api.yousign.app/v3 for production.
YOUSIGN_BASE_URL="https://api-sandbox.yousign.app/v3"

# ─── Admin dashboard ─────────────────────────────────────────
# At least 8 characters. Used for /admin login.
ADMIN_PASSWORD="change-me-min-8-chars"

# ─── Vercel cron auth ────────────────────────────────────────
# At least 16 characters. Required header on /api/cron/* requests.
CRON_SECRET="generate-a-long-random-string-here"

# ─── App base URL ────────────────────────────────────────────
# Used for Stripe success/cancel URLs and email links.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Partners inquiry routing (optional) ────────────────────
# Where /api/partners-inquiry delivers B2B lead emails.
# Set to your personal inbox in Vercel production; otherwise falls back
# to booking@stacey.de.
PARTNERS_INQUIRY_EMAIL=""

# ─── Consent + Tracking (optional, production only) ─────────
# Cookiebot Domain Group ID. Required for GDPR-compliant consent banner.
# Register at cookiebot.com → Domain Settings → copy "CBID".
NEXT_PUBLIC_COOKIEBOT_CBID=""
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# Only loaded if NEXT_PUBLIC_COOKIEBOT_CBID is also set.
NEXT_PUBLIC_GA4_ID=""
# Google Ads Conversion ID (format: AW-XXXXXXXXXX).
# Only loaded if NEXT_PUBLIC_COOKIEBOT_CBID is also set.
NEXT_PUBLIC_GOOGLE_ADS_ID=""

# ─── Test mode (optional) ────────────────────────────────────
# Comma-separated email whitelist. While set, only these recipients receive
# any outgoing email — useful for testing without spamming real users.
# Leave empty in production.
TEST_MODE_EMAILS=""
